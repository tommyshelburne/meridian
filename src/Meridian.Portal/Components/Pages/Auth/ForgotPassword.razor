@page "/forgot-password"
@layout PublicLayout

<PageTitle>Reset password · Meridian</PageTitle>

<section class="auth-card">
    <h1>Reset your password</h1>

    @if (Sent == "1")
    {
        <div class="auth-ok" role="status">
            If an account matches that email, a reset link is on its way. Check your inbox.
        </div>
    }

    <form method="post" action="/auth/forgot-password">
        <AntiforgeryToken />

        <label>Email
            <input type="email" name="Email" required autocomplete="email" />
        </label>

        <button type="submit">Send reset link</button>
    </form>

    <p class="auth-meta"><a href="/login">Back to sign in</a></p>
</section>

@code {
    [SupplyParameterFromQuery] public string? Sent { get; set; }
}
