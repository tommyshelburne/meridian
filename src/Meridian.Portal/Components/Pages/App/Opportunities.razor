@page "/app/{Slug}/opportunities"
@layout AppLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Meridian.Application.Opportunities
@using Meridian.Domain.Common
@using Meridian.Domain.Opportunities

<PageTitle>Opportunities · Meridian</PageTitle>

<h1>Opportunity queue</h1>
<p class="page-lede">
    Scored opportunities awaiting a decision. Sorted by total score, highest first.
</p>

@if (!string.IsNullOrEmpty(Error))
{
    <div class="auth-error" role="alert">@Error</div>
}
@if (Saved == "1")
{
    <div class="auth-ok" role="status">Decision recorded.</div>
}

@if (_opportunities is null)
{
    <p class="muted">Loading…</p>
}
else if (_opportunities.Count == 0)
{
    <div class="empty-state">
        <p>No scored opportunities yet.</p>
        <p class="muted">Once the worker ingests and scores opportunities from your configured sources, they'll show up here for review.</p>
    </div>
}
else
{
    <table class="opp-table">
        <thead>
            <tr>
                <th>Score</th>
                <th>Title</th>
                <th>Agency</th>
                <th>Source</th>
                <th>Seats</th>
                <th>Deadline</th>
                <th>Decision</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var opp in _opportunities)
            {
                <tr class="@RowClassFor(opp)">
                    <td>
                        <div class="score">@(opp.Score?.Total) <span class="score-max">/14</span></div>
                        <div class="verdict @VerdictClass(opp.Score?.Verdict)">@opp.Score?.Verdict</div>
                    </td>
                    <td>
                        <div class="title">@opp.Title</div>
                        <div class="muted">@opp.ExternalId</div>
                    </td>
                    <td>
                        <div>@opp.Agency.Name</div>
                        <div class="muted">@opp.Agency.Type @(opp.Agency.State is null ? "" : $"· {opp.Agency.State}")</div>
                    </td>
                    <td>@opp.Source</td>
                    <td>
                        @if (opp.EstimatedSeats is { } seats)
                        {
                            <div>@seats.ToString("N0")</div>
                            <div class="muted">@opp.SeatEstimateConfidence</div>
                        }
                        else
                        {
                            <span class="muted">—</span>
                        }
                    </td>
                    <td>@(opp.ResponseDeadline?.ToString("yyyy-MM-dd") ?? "—")</td>
                    <td>
                        <form method="post" action="/app/@Slug/opportunities/decide" class="decision-form">
                            <AntiforgeryToken />
                            <input type="hidden" name="OpportunityId" value="@opp.Id" />
                            <button type="submit" name="Decision" value="Pursue" class="btn-pursue">Pursue</button>
                            <button type="submit" name="Decision" value="Partner" class="btn-partner">Partner</button>
                            <button type="submit" name="Decision" value="Watch" class="btn-watch">Watch</button>
                            <button type="submit" name="Decision" value="Reject" class="btn-reject">Reject</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? Saved { get; set; }

    [Inject] private OpportunityQueueService Queue { get; set; } = default!;
    [Inject] private Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthState { get; set; } = default!;

    private IReadOnlyList<Opportunity>? _opportunities;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var tid = state.User.FindFirst(Meridian.Portal.Auth.ClaimsBuilder.TenantIdClaim)?.Value;
        if (Guid.TryParse(tid, out var tenantId))
            _opportunities = await Queue.GetQueueAsync(tenantId, CancellationToken.None);
    }

    private static string RowClassFor(Opportunity opp) => opp.Score?.Verdict switch
    {
        ScoreVerdict.Pursue => "row-pursue",
        ScoreVerdict.Partner => "row-partner",
        _ => string.Empty
    };

    private static string VerdictClass(ScoreVerdict? v) => v switch
    {
        ScoreVerdict.Pursue => "verdict-pursue",
        ScoreVerdict.Partner => "verdict-partner",
        ScoreVerdict.NoBid => "verdict-nobid",
        _ => string.Empty
    };
}

