@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="mkt">
    <header class="mkt-header">
        <div class="mkt-container mkt-header-inner">
            <a class="mkt-brand" href="/">
                <span class="mkt-brand-mark" aria-hidden="true"></span>
                <span class="mkt-brand-word">Meridian</span>
            </a>
            <nav class="mkt-nav" aria-label="Primary">
                <a href="/features">Features</a>
                <a href="/pricing">Pricing</a>
                <a href="/about">About</a>
                <a href="/help">Docs</a>
            </nav>
            <details class="mkt-menu">
                <summary>Menu</summary>
                <nav class="mkt-menu-panel" aria-label="Primary mobile">
                    <a href="/features">Features</a>
                    <a href="/pricing">Pricing</a>
                    <a href="/about">About</a>
                    <a href="/help">Docs</a>
                </nav>
            </details>
            <div class="mkt-header-cta">
                <AuthorizeView>
                    <Authorized>
                        <a class="mkt-link" href="/app/@TenantSlug(context.User)">Open app →</a>
                    </Authorized>
                    <NotAuthorized>
                        <a class="mkt-link" href="/login">Sign in</a>
                        <a class="mkt-btn mkt-btn-primary" href="mailto:hello@meridianbd.dev?subject=Meridian%20demo">Get a demo</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    <main class="mkt-main">
        @Body
    </main>

    <footer class="mkt-footer">
        <div class="mkt-container mkt-footer-inner">
            <div class="mkt-footer-brand">
                <a class="mkt-brand mkt-brand-footer" href="/">
                    <span class="mkt-brand-mark" aria-hidden="true"></span>
                    <span class="mkt-brand-word">Meridian</span>
                </a>
                <p class="mkt-footer-tag">Procurement outreach, scored and sequenced.</p>
            </div>
            <div class="mkt-footer-cols">
                <div>
                    <h4>Product</h4>
                    <a href="/features">Features</a>
                    <a href="/pricing">Pricing</a>
                    <a href="/help">Docs</a>
                </div>
                <div>
                    <h4>Company</h4>
                    <a href="/about">About</a>
                    <a href="mailto:hello@meridianbd.dev">Contact</a>
                </div>
                <div>
                    <h4>Account</h4>
                    <a href="/login">Sign in</a>
                    <a href="/signup">Create workspace</a>
                </div>
            </div>
        </div>
        <div class="mkt-container mkt-footer-base">
            <span>© @DateTime.UtcNow.Year Meridian</span>
            <span class="mkt-footer-meta">Made for federal, state, and local pursuit teams.</span>
        </div>
    </footer>
</div>

@code {
    private static string TenantSlug(System.Security.Claims.ClaimsPrincipal user) =>
        user.FindFirst(Meridian.Portal.Auth.ClaimsBuilder.TenantSlugClaim)?.Value ?? "";
}

<style>
    /* ---------- design tokens ---------- */
    .mkt {
        --bg: #FAFAF7;
        --surface: #FFFFFF;
        --paper: #F5F0E6;
        --ink: #0B1620;
        --ink-2: #3A4654;
        --ink-3: #7A8290;
        --line: #E7E4DC;
        --line-strong: #D6D1C5;
        --accent: #0F4F3A;
        --accent-hover: #0A3E2D;
        --accent-soft: #C8E8D5;
        --accent-tint: #E9F4EE;
        --warn: #B8541E;
        --radius: 10px;
        --radius-lg: 16px;
        --shadow-card: 0 1px 0 rgba(11, 22, 32, 0.04), 0 8px 24px -12px rgba(11, 22, 32, 0.10);
        --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
        --font-mono: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;

        font-family: var(--font);
        color: var(--ink);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        font-feature-settings: 'cv11', 'ss01';
        line-height: 1.5;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .mkt-container {
        max-width: 1200px;
        margin: 0 auto;
        padding-left: 32px;
        padding-right: 32px;
        width: 100%;
        box-sizing: border-box;
    }

    /* ---------- header ---------- */
    .mkt-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(250, 250, 247, 0.93);
        backdrop-filter: saturate(140%) blur(12px);
        -webkit-backdrop-filter: saturate(140%) blur(12px);
        border-bottom: 1px solid var(--line);
    }
    .mkt-header-inner {
        display: flex;
        align-items: center;
        gap: 32px;
        height: 64px;
    }
    .mkt-brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: var(--ink);
        font-weight: 600;
        letter-spacing: -0.01em;
    }
    .mkt-brand-mark {
        width: 22px;
        height: 22px;
        border-radius: 6px;
        background: linear-gradient(135deg, var(--accent) 0%, #1B6E50 60%, #2C8C68 100%);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
        position: relative;
    }
    .mkt-brand-mark::after {
        content: "";
        position: absolute;
        inset: 6px;
        border: 1.5px solid rgba(255,255,255,0.85);
        border-bottom: none;
        border-right: none;
        border-radius: 3px 0 0 0;
    }
    .mkt-nav {
        display: flex;
        gap: 24px;
        margin-left: 8px;
    }
    .mkt-nav a {
        color: var(--ink-2);
        text-decoration: none;
        font-size: 14.5px;
        font-weight: 500;
        transition: color 120ms ease;
    }
    .mkt-nav a:hover { color: var(--ink); }

    /* ---------- mobile disclosure menu ---------- */
    .mkt-menu {
        display: none;
        position: relative;
    }
    .mkt-menu > summary {
        list-style: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        padding: 7px 12px;
        border: 1px solid var(--line-strong);
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        color: var(--ink);
        background: var(--surface);
    }
    .mkt-menu > summary::-webkit-details-marker { display: none; }
    .mkt-menu > summary:hover { border-color: var(--ink); }
    .mkt-menu-panel {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        display: flex;
        flex-direction: column;
        min-width: 180px;
        padding: 6px;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow-card);
        z-index: 60;
    }
    .mkt-menu-panel a {
        color: var(--ink-2);
        text-decoration: none;
        font-size: 14.5px;
        font-weight: 500;
        padding: 9px 10px;
        border-radius: 6px;
    }
    .mkt-menu-panel a:hover {
        color: var(--ink);
        background: var(--paper);
    }

    .mkt-header-cta {
        margin-left: auto;
        display: inline-flex;
        align-items: center;
        gap: 18px;
    }
    .mkt-link {
        color: var(--ink-2);
        text-decoration: none;
        font-weight: 500;
        font-size: 14.5px;
    }
    .mkt-link:hover { color: var(--ink); }
    .mkt-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14.5px;
        text-decoration: none;
        line-height: 1;
        border: 1px solid transparent;
        transition: background 120ms ease, color 120ms ease, transform 120ms ease;
        cursor: pointer;
    }
    .mkt-btn-primary {
        background: var(--ink);
        color: var(--bg);
    }
    .mkt-btn-primary:hover {
        background: var(--accent);
    }
    .mkt-btn-secondary {
        background: transparent;
        color: var(--ink);
        border-color: var(--line-strong);
    }
    .mkt-btn-secondary:hover {
        background: var(--surface);
        border-color: var(--ink);
    }
    .mkt-btn-lg {
        padding: 14px 24px;
        font-size: 15.5px;
    }

    /* ---------- main ---------- */
    .mkt-main {
        flex: 1;
    }

    /* ---------- shared page chrome ---------- */
    .mkt h1, .mkt h2, .mkt h3, .mkt h4 { margin: 0; color: var(--ink); }
    .mkt p { color: var(--ink-2); }

    .eyebrow {
        display: inline-block;
        font-size: 12px;
        letter-spacing: 0.12em;
        font-weight: 600;
        text-transform: uppercase;
        color: var(--accent);
        background: var(--accent-tint);
        padding: 6px 10px;
        border-radius: 6px;
        margin-bottom: 18px;
    }

    .mkt-section { padding: 96px 0; }
    .section-head { max-width: 720px; margin-bottom: 56px; }

    .page-hero {
        padding: 96px 0 48px;
        position: relative;
        overflow: hidden;
    }
    .page-hero::before {
        content: "";
        position: absolute;
        inset: -200px -300px 0 30%;
        background: radial-gradient(circle at 70% 30%, rgba(200, 232, 213, 0.35), transparent 60%);
        z-index: 0;
        pointer-events: none;
    }
    .page-hero > .mkt-container { position: relative; z-index: 1; }
    .page-hero h1 {
        font-size: 56px;
        line-height: 1.05;
        letter-spacing: -0.035em;
        font-weight: 650;
        margin: 12px 0 18px;
        max-width: 880px;
    }
    .page-hero .lead {
        font-size: 18px;
        color: var(--ink-2);
        max-width: 720px;
        line-height: 1.55;
        margin: 0;
    }

    .cta-band {
        margin: 64px 0 0;
        padding: 56px 0;
        background: var(--ink);
        color: var(--bg);
    }
    .cta-band-inner {
        display: flex; align-items: center; justify-content: space-between; gap: 32px;
        flex-wrap: wrap;
    }
    .cta-band h2 {
        font-size: 32px;
        margin: 0;
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--bg);
    }

    /* ---------- footer ---------- */
    .mkt-footer {
        border-top: 1px solid var(--line);
        background: var(--surface);
        padding: 64px 0 56px;
    }
    .mkt-footer-inner {
        display: grid;
        grid-template-columns: 1.2fr 2fr;
        gap: 64px;
        margin-bottom: 48px;
    }
    .mkt-footer-tag {
        color: var(--ink-3);
        margin: 12px 0 0;
        font-size: 14.5px;
        max-width: 280px;
    }
    .mkt-brand-footer .mkt-brand-word {
        font-size: 15px;
    }
    .mkt-footer-cols {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 32px;
    }
    .mkt-footer-cols h4 {
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--ink-3);
        margin: 0 0 14px;
    }
    .mkt-footer-cols a {
        display: block;
        color: var(--ink);
        text-decoration: none;
        font-size: 14.5px;
        padding: 4px 0;
    }
    .mkt-footer-cols a:hover { color: var(--accent); }
    .mkt-footer-base {
        border-top: 1px solid var(--line);
        padding-top: 24px;
        display: flex;
        justify-content: space-between;
        font-size: 13.5px;
        color: var(--ink-3);
    }

    @@media (max-width: 960px) {
        .page-hero h1 { font-size: 40px; }
    }
    @@media (max-width: 720px) {
        .mkt-nav { display: none; }
        .mkt-menu { display: block; }
        .mkt-footer-inner { grid-template-columns: 1fr; gap: 40px; }
        .mkt-footer-cols { grid-template-columns: repeat(2, 1fr); }
        .mkt-footer-base { flex-direction: column; gap: 8px; }
    }
</style>
