@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<AuthorizeView>
    <Authorized>
        <div class="app-shell">
            <aside class="app-sidebar">
                <a class="brand" href="/app/@TenantSlug(context.User)">Meridian</a>
                <nav>
                    <a href="/app/@TenantSlug(context.User)">Dashboard</a>
                    <a href="/app/@TenantSlug(context.User)/opportunities">Opportunities</a>
                    <a href="/app/@TenantSlug(context.User)/pipeline">Pipeline</a>
                    <a href="/app/@TenantSlug(context.User)/enrichment">Enrichment</a>
                    <a href="/app/@TenantSlug(context.User)/replies">Replies</a>
                    <a href="/app/@TenantSlug(context.User)/activity">Activity</a>
                    <a href="/app/@TenantSlug(context.User)/sources">Sources</a>
                    <a href="/app/@TenantSlug(context.User)/members">Members</a>
                    <a href="/app/@TenantSlug(context.User)/settings">Settings</a>
                    <a href="/app/@TenantSlug(context.User)/settings/outbound">Outbound</a>
                    <a href="/app/@TenantSlug(context.User)/settings/sequences">Sequences</a>
                    <a href="/app/@TenantSlug(context.User)/settings/scoring">Scoring</a>
                    <a href="/app/@TenantSlug(context.User)/settings/crm">CRM</a>
                    <a href="/help" class="nav-help">Help</a>
                </nav>
                <form method="post" action="/auth/logout" class="logout-form">
                    <AntiforgeryToken />
                    <button type="submit">Sign out</button>
                </form>
            </aside>
            <main class="app-main">
                <header class="app-topbar">
                    <div class="user-meta">
                        <span class="user-name">@context.User.Identity!.Name</span>
                        <span class="user-role">@context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                    </div>
                </header>
                <div class="app-content">
                    @Body
                </div>
            </main>
        </div>
    </Authorized>
    <NotAuthorized>
        @{ Nav.NavigateTo($"/login?return={Uri.EscapeDataString(Nav.Uri)}", forceLoad: true); }
    </NotAuthorized>
</AuthorizeView>

@code {
    private static string TenantSlug(System.Security.Claims.ClaimsPrincipal user) =>
        user.FindFirst(Meridian.Portal.Auth.ClaimsBuilder.TenantSlugClaim)?.Value ?? "";
}
